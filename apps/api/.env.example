# ========================
# RAHO API — Environment Variables
# Copy ke .env dan sesuaikan nilainya
# ========================

# ── Application ─────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# ── Database (PostgreSQL) ────────────────────────
# Sudah dikonfigurasi di docker-compose.dev.yml
DATABASE_URL="postgresql://raho_user:raho_password@localhost:5432/raho-db?schema=public"

# ── JWT Tokens ───────────────────────────────────
JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── MinIO Object Storage ─────────────────────────
# Sudah dikonfigurasi di docker-compose.dev.yml
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=raho_minio_user
MINIO_SECRET_KEY=raho_minio_secret
MINIO_BUCKET=raho-uploads
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000

# ── CORS ─────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
