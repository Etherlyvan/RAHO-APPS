# ═══════════════════════════════════════════════════════════════
.next/
out/
next-env.d.ts
.vercel

# ═══════════════════════════════════════════════════════════════
# Temporary Files & Cache
# ═══════════════════════════════════════════════════════════════
.cache/
.temp/
.tmp/
tmp/
temp/
*.tmp
*.temp

# ═══════════════════════════════════════════════════════════════
# Documentation Generated Files
# ═══════════════════════════════════════════════════════════════
# Keep markdown files but ignore generated docs
# docs/generated/

# ═══════════════════════════════════════════════════════════════
# Backup Files
# ═══════════════════════════════════════════════════════════════
*.bak
*.backup
*.old
*.orig

# ═══════════════════════════════════════════════════════════════
# Security & Sensitive Data
# ═══════════════════════════════════════════════════════════════
# SSL certificates
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx

# SSH keys
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# Secrets
secrets/
.secrets/
*.secret

# ═══════════════════════════════════════════════════════════════
# Project Specific
# ═══════════════════════════════════════════════════════════════
# Kiro AI generated files (keep the important ones)
API_URL_FIX.md
API_URL_FIX_COMPLETE.md
STOCK_REQUEST_UI_COMPLETE.md

# Null files (Windows PowerShell artifacts)
$null
*/$null
**/$null

# Lock files (optional - uncomment if you want to ignore them)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ═══════════════════════════════════════════════════════════════
# Miscellaneous
# ═══════════════════════════════════════════════════════════════
.eslintcache
.stylelintcache
.parcel-cache/
.vite/
