# ═══════════════════════════════════════════════════════════════
# Node.js & Package Managers
# ═══════════════════════════════════════════════════════════════
node_modules/
.npm
.pnpm-store/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ═══════════════════════════════════════════════════════════════
# Build Output & Distribution
# ═══════════════════════════════════════════════════════════════
dist/
build/
.next/
out/
*.tsbuildinfo
.turbo/
.vercel/

# ═══════════════════════════════════════════════════════════════
# Environment Variables (NEVER COMMIT!)
# ═══════════════════════════════════════════════════════════════
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
apps/api/.env
apps/web/.env.local

# Keep example files
!.env.example
!.env.local.example
!apps/api/.env.example
!apps/web/.env.local.example

# ═══════════════════════════════════════════════════════════════
# Database & Prisma
# ═══════════════════════════════════════════════════════════════
# Migrations are tracked, but you might want to ignore them in some cases
# apps/api/prisma/migrations/

# SQLite databases (if used for development)
*.db
*.db-journal
*.sqlite
*.sqlite3

# Database dumps
*.sql.gz
*.dump

# ═══════════════════════════════════════════════════════════════
# MinIO / Object Storage
# ═══════════════════════════════════════════════════════════════
# Local MinIO data (if running locally)
.minio/
minio-data/

# Uploaded files (if stored locally during development)
uploads/
temp-uploads/

# ═══════════════════════════════════════════════════════════════
# Logs
# ═══════════════════════════════════════════════════════════════
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ═══════════════════════════════════════════════════════════════
# Operating System Files
# ═══════════════════════════════════════════════════════════════
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ═══════════════════════════════════════════════════════════════
# IDE & Editor Files
# ═══════════════════════════════════════════════════════════════
# VSCode
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-snippets

# Keep recommended extensions and tasks
!.vscode/extensions.json
!.vscode/tasks.json

# JetBrains IDEs (WebStorm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr

# Vim
*.swp
*.swo
*~
.*.sw[a-z]

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# Sublime Text
*.sublime-workspace
*.sublime-project

# ═══════════════════════════════════════════════════════════════
# Testing & Coverage
# ═══════════════════════════════════════════════════════════════
coverage/
.nyc_output/
*.lcov
.coverage
htmlcov/
.pytest_cache/
.jest/

# ═══════════════════════════════════════════════════════════════
# Docker
# ═══════════════════════════════════════════════════════════════
# Docker volumes are managed externally
docker-compose.override.yml
.dockerignore

# ═══════════════════════════════════════════════════════════════
# TypeScript
# ═══════════════════════════════════════════════════════════════
*.tsbuildinfo
.tsbuildinfo

